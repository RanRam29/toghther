{
  "name": "toghther",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "cd apps/mobile && npx expo start",
    "lint": "cd apps/mobile && npx expo lint",
    "typecheck": "cd apps/mobile && npx tsc --noEmit",
    "types:generate": "npx supabase gen types typescript --linked > packages/shared/src/types/database.ts",
    "eas-build-post-install": "npm rebuild lightningcss"
  },
  "engines": {
    "node": ">=18"
  },
  "overrides": {
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-native": "0.79.6"
  }
}
