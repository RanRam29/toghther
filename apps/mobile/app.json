{
  "expo": {
    "name": "Together",
    "slug": "together",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "together",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.toghther.app",
      "buildNumber": "1",
      "infoPlist": {
        "CFBundleAllowMixedLocalizations": true,
        "CFBundleLocalizations": ["he", "en"],
        "CFBundleDevelopmentRegion": "he",
        "NSPhotoLibraryUsageDescription": "יש צורך בהרשאה לגלריה כדי לצרף מסמכי אימות",
        "NSCameraUsageDescription": "יש צורך בהרשאה למצלמה כדי לצלם מסמכי אימות",
        "NSLocationWhenInUseUsageDescription": "יש צורך במיקום כדי לבצע צ'ק-אין GPS בתחילת המשמרת (EVV)"
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#EEEDFE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "com.toghther.app",
      "versionCode": 1,
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "READ_EXTERNAL_STORAGE",
        "READ_MEDIA_IMAGES",
        "CAMERA"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-localization",
      "expo-secure-store",
      "expo-font",
      [
        "expo-image-picker",
        {
          "photosPermission": "יש צורך בהרשאה לגלריה כדי לצרף מסמכי אימות",
          "cameraPermission": "יש צורך בהרשאה למצלמה כדי לצלם מסמכי אימות"
        }
      ],
      "expo-document-picker",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "יש צורך במיקום כדי לבצע צ'ק-אין GPS בתחילת המשמרת (EVV)"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "98698b7b-8cc0-4b78-85ab-f79438f0aec9"
      }
    },
    "owner": "alwayes-together"
  }
}
