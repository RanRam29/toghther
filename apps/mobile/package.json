    "@react-native-community/netinfo": "11.4.1",
    "@supabase/supabase-js": "^2.49.1",
    "@tanstack/react-query": "^5.69.0",
    "expo": "~53.0.0",
    "expo-constants": "~17.1.8",
    "expo-device": "~7.1.4",
    "expo-document-picker": "^13.1.6",
    "expo-font": "~13.3.2",
    "expo-haptics": "~14.1.4",
